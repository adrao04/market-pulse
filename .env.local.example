# Neon PostgreSQL connection string
# Get this from your Neon project dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# SendGrid email alerts (optional — alerts are skipped if not set)
# Sign up at https://sendgrid.com (free tier: 100 emails/day)
SENDGRID_API_KEY=SG.your_api_key_here
ALERT_FROM_EMAIL=alerts@yourdomain.com

# Vercel Cron secret — add this in Vercel dashboard too
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
